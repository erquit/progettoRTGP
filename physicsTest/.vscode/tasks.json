{
    "tasks": [
        {
            "type": "shell",
            "label": "build-glfw",
            "command": "/usr/bin/g++-13",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}",
                "-isystem", "/dev/null",
                "-ILibraries/include",
                "-LLibraries/lib",
                "-lglfw3",
                "-ldl",
                "-lm",
                "-lpthread",
                "-lX11"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "Task generated by Debugger."
        }
    ],
    "version": "2.0.0"
}